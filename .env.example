AGORA_APP_ID=your_agora_app_id
AGORA_TEMP_RTC_TOKEN=your_temp_rtc_token_generated_for_channel_Likeehit
AGORA_TOKEN_SERVER_URL=https://asia-south1-your-project-id.cloudfunctions.net/getAgoraRtcToken
LIKEEHIT_LIVE_API_BASE_URL=https://asia-south1-your-project-id.cloudfunctions.net
AGORA_ALLOW_NO_TOKEN=false
GOOGLE_WEB_CLIENT_ID=your_web_oauth_client_id.apps.googleusercontent.com
GOOGLE_IOS_CLIENT_ID=your_ios_oauth_client_id.apps.googleusercontent.com
GOOGLE_SERVER_CLIENT_ID=your_web_oauth_client_id.apps.googleusercontent.com

# Token settings must match:
# Channel name: Likeehit
# For production, set up the backend token server and point AGORA_TOKEN_SERVER_URL to it.
# Google Sign-In:
# - Web uses GOOGLE_WEB_CLIENT_ID
# - iOS uses GOOGLE_IOS_CLIENT_ID plus a URL scheme in ios/Runner/Info.plist
# - Android can use google-services.json, but GOOGLE_SERVER_CLIENT_ID is kept as an override
